# UAP - Universidad Autónoma del Paraguay
# Configuración para SiteGround (Apache) - URLs limpias equivalentes a uap.edu.py

DirectoryIndex index.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ---------------------------------------------------------------
    # URLs limpias (sin .html), replicando las rutas de uap.edu.py
    # ---------------------------------------------------------------

    # /carreras/  ->  pages/carreras.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^carreras/?$ pages/carreras.html [L]

    # /carreras/{slug}/  ->  pages/carreras/{slug}.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^carreras/([a-z0-9-]+)/?$ pages/carreras/$1.html [L]

    # /posgrados/  ->  pages/posgrados.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^posgrados/?$ pages/posgrados.html [L]

    # /posgrados/{slug}/  ->  pages/posgrados/{slug}.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^posgrados/([a-z0-9-]+)/?$ pages/posgrados/$1.html [L]

    # Páginas institucionales de primer nivel
    # /institucional/, /contacto/, /estudiantes/, /inscripcion/, /investigacion/, /noticias/, /privacidad/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(institucional|contacto|estudiantes|inscripcion|investigacion|noticias|privacidad)/?$ pages/$1.html [L]
</IfModule>

# ---------------------------------------------------------------
# Cabeceras de seguridad (equivalentes a las definidas en vercel.json)
# ---------------------------------------------------------------
<IfModule mod_headers.c>
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.bitrix24.es; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.bitrix24.es; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.bitrix24.es; frame-src 'self' https://*.bitrix24.es; frame-ancestors 'none'; form-action 'self' https://*.bitrix24.es; base-uri 'self'; object-src 'none';"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
</IfModule>

# ---------------------------------------------------------------
# Caché de assets estáticos
# ---------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType application/pdf "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|png|jpe?g|svg|webp|gif)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
